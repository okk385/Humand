# Humand environment configuration
# Copy this file to .env and fill in the values you need.

# Storage
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000
HUMAND_PUBLIC_BASE_URL=http://localhost:8000
HUMAND_SIMULATOR_URL=http://localhost:5000

# Approval defaults
APPROVAL_TIMEOUT=3600
APPROVERS=admin@company.com,manager@company.com
HUMAND_API_KEY=
HUMAND_NOTIFICATION_PROVIDERS=
# Optional: set a stable local login for the bundled Web UI demo.
# HUMAND_BOOTSTRAP_ADMIN_PASSWORD=humand-demo

# Optional webhook channels
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# Feishu interactive cards
# Set HUMAND_NOTIFICATION_PROVIDERS=feishu to enable this provider.
# Common shared-inbox setup:
#   FEISHU_RECEIVE_ID_TYPE=chat_id
#   FEISHU_RECEIVE_ID=<your shared chat id>
FEISHU_OPEN_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_CALLBACK_VERIFICATION_TOKEN=

